{
  "name": "concat-app-electron",
  "version": "1.0.0",
  "description": "Multi-folder file concatenator",
  "author": "Your Name",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dev-build": "electron-builder --win --dir"
  },
  "build": {
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "!node_modules/**/*"
    ],
    "appId": "com.yourname.concatapp",
    "productName": "FolderConcatenator",
    "win": {
      "target": "portable"
    },
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
